---
import Navbar from '../components/navbar.astro';
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Hesed Core | Innovación Tecnológica para Empresas</title>
        <!-- Tipografía moderna -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Inter', sans-serif; }
            .hero-gradient {
                background: linear-gradient(135deg, 
                    rgba(16, 185, 129, 0.05) 0%, 
                    rgba(59, 130, 246, 0.05) 50%, 
                    rgba(245, 158, 11, 0.03) 100%);
            }
            .floating-shapes {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                overflow: hidden;
                z-index: 0;
            }
            .shape {
                position: absolute;
                border-radius: 50%;
                background: linear-gradient(45deg, rgba(16, 185, 129, 0.1), rgba(59, 130, 246, 0.1));
                animation: float 6s ease-in-out infinite;
            }
            .shape:nth-child(1) {
                width: 80px;
                height: 80px;
                top: 10%;
                left: 10%;
                animation-delay: 0s;
            }
            .shape:nth-child(2) {
                width: 60px;
                height: 60px;
                top: 20%;
                right: 15%;
                animation-delay: 2s;
            }
            .shape:nth-child(3) {
                width: 100px;
                height: 100px;
                bottom: 20%;
                left: 20%;
                animation-delay: 4s;
            }
            @keyframes float {
                0%, 100% { transform: translateY(0px) rotate(0deg); }
                50% { transform: translateY(-20px) rotate(180deg); }
            }
        </style>
    </head>
    <body class="bg-white text-gray-900 hero-gradient min-h-screen">
        <Navbar />

        <!-- HERO SECTION MODERNO -->
        <section class="relative pt-32 pb-20 px-6 overflow-hidden">
            <div class="floating-shapes">
                <div class="shape"></div>
                <div class="shape"></div>
                <div class="shape"></div>
            </div>
            
            <div class="max-w-6xl mx-auto text-center relative z-10">
                <!-- Badge Premium -->
                <div class="inline-flex items-center gap-3 bg-gradient-to-r from-green-100 to-blue-100 border border-green-200 px-6 py-3 rounded-full mb-10 shadow-lg">
                    <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                    <span class="text-sm font-bold text-gray-700 uppercase tracking-wider">🏆 Startup Tecnológica Líder • García, N.L.</span>
                    <div class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></div>
                </div>
                
                <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-8 leading-tight">
                    Impulsamos tu <span class="gradient-text">negocio</span> con
                    <br><span class="text-orange-500">tecnología inteligente</span>
                </h1>
                
                <p class="text-xl md:text-2xl text-gray-600 max-w-4xl mx-auto mb-12 leading-relaxed font-light">
                    Transformamos operaciones complejas en flujos automatizados. 
                    <strong class="text-gray-900 font-semibold">Hesed Core</strong> diseña ecosistemas digitales que escalan con tu crecimiento.
                </p>
                
                <!-- CTA Buttons Premium -->
                <div class="flex flex-col sm:flex-row justify-center gap-6 mt-12">
                    <a href="#productos" class="group bg-gradient-to-r from-green-500 to-blue-600 text-white px-12 py-5 rounded-2xl font-bold text-xl shadow-2xl hover:shadow-green-500/25 hover-lift transition-all duration-300">
                        <span class="flex items-center gap-3">
                            Explorar Productos
                            <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </span>
                    </a>
                    
                    <a href="#contacto" class="group bg-white border-2 border-gray-200 text-gray-700 px-12 py-5 rounded-2xl font-bold text-xl hover:border-green-400 hover:text-green-600 transition-all duration-300 hover-lift shadow-lg">
                        <span class="flex items-center gap-3">
                            Agendar Consulta
                            <svg class="w-6 h-6 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </span>
                    </a>
                </div>

                <!-- Trust Indicators -->
                <div class="flex justify-center items-center gap-8 mt-16 opacity-70">
                    <div class="text-center">
                        <div class="text-3xl font-bold text-green-600 mb-1">500+</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">Clientes Satisfechos</div>
                    </div>
                    <div class="w-px h-12 bg-gray-300"></div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-blue-600 mb-1">99.9%</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">Uptime Garantizado</div>
                    </div>
                    <div class="w-px h-12 bg-gray-300"></div>
                    <div class="text-center">
                        <div class="text-3xl font-bold text-orange-500 mb-1">24/7</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">Soporte Técnico</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN SOBRE NOSOTROS MODERNA -->
        <section id="sobre-nosotros" class="py-32 px-6 bg-white">
            <div class="max-w-7xl mx-auto">
                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <div class="slide-up">
                        <div class="inline-flex items-center gap-2 bg-blue-100 border border-blue-200 px-4 py-2 rounded-full mb-6">
                            <span class="text-blue-600">🎯</span>
                            <span class="text-sm font-semibold text-blue-700 uppercase tracking-wider">Nuestra Historia</span>
                        </div>
                        
                        <h2 class="text-5xl md:text-6xl font-black tracking-tight mb-8 text-gray-900 leading-tight">
                            Innovación con <span class="gradient-text">Propósito</span>
                        </h2>
                        
                        <p class="text-xl text-gray-600 mb-8 leading-relaxed">
                            Hesed Core nace de la visión de democratizar el acceso a tecnología de vanguardia para empresas mexicanas. 
                            Combinamos el rigor de la ingeniería de software con el profundo entendimiento de los procesos de negocio locales.
                        </p>
                        
                        <p class="text-xl text-gray-600 mb-10 leading-relaxed">
                            Nuestro enfoque se basa en crear soluciones escalables que no solo resuelven problemas actuales, 
                            sino que preparan a las empresas para el futuro digital.
                        </p>
                        
                        <div class="grid grid-cols-3 gap-6 mb-10">
                            <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-2xl border border-green-200">
                                <div class="text-4xl font-black text-green-600 mb-2">500+</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Proyectos</div>
                            </div>
                            <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl border border-blue-200">
                                <div class="text-4xl font-black text-blue-600 mb-2">99%</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Satisfacción</div>
                            </div>
                            <div class="text-center p-4 bg-gradient-to-br from-orange-50 to-orange-100 rounded-2xl border border-orange-200">
                                <div class="text-4xl font-black text-orange-500 mb-2">5</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Años</div>
                            </div>
                        </div>
                        
                        <a href="#equipo" class="inline-flex items-center gap-3 bg-gradient-to-r from-green-500 to-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:from-green-600 hover:to-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl">
                            Conoce Nuestro Equipo
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                            </svg>
                        </a>
                    </div>
                    
                    <div class="relative slide-up">
                        <div class="bg-gradient-to-br from-green-400/10 to-blue-500/10 rounded-3xl p-12">
                            <div class="text-center">
                                <div class="w-24 h-24 bg-gradient-to-br from-green-400 to-blue-500 rounded-3xl mx-auto mb-8 flex items-center justify-center text-5xl shadow-2xl">
                                    🚀
                                </div>
                                <h3 class="text-3xl font-bold text-gray-900 mb-6">Nuestra Misión</h3>
                                <p class="text-gray-600 text-lg leading-relaxed mb-8">
                                    Democratizar el acceso a tecnología de vanguardia para empresas de todos los tamaños en México, 
                                    creando soluciones que transforman operaciones y generan crecimiento sostenible.
                                </p>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="bg-white/70 p-4 rounded-xl border border-green-200">
                                        <div class="text-2xl mb-2">⚡</div>
                                        <div class="font-semibold text-gray-800">Velocidad</div>
                                        <div class="text-sm text-gray-600">Implementación rápida</div>
                                    </div>
                                    <div class="bg-white/70 p-4 rounded-xl border border-blue-200">
                                        <div class="text-2xl mb-2">🎯</div>
                                        <div class="font-semibold text-gray-800">Precisión</div>
                                        <div class="text-sm text-gray-600">Resultados medibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Elementos decorativos -->
                        <div class="absolute -top-4 -right-4 w-20 h-20 bg-gradient-to-br from-orange-400 to-orange-500 rounded-2xl opacity-20 animate-pulse"></div>
                        <div class="absolute -bottom-6 -left-6 w-16 h-16 bg-gradient-to-br from-green-400 to-green-500 rounded-2xl opacity-30 animate-pulse" style="animation-delay: 1s;"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN PRODUCTOS MODERNA -->
        <section id="productos" class="py-32 px-6 bg-gradient-to-br from-gray-50 to-white">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-20">
                    <div class="inline-flex items-center gap-2 bg-orange-100 border border-orange-200 px-4 py-2 rounded-full mb-6">
                        <span class="text-orange-600">🚀</span>
                        <span class="text-sm font-semibold text-orange-700 uppercase tracking-wider">Ecosistema Completo</span>
                    </div>
                    <h2 class="text-5xl md:text-6xl font-black tracking-tight mb-6 gradient-text">
                        Nuestros Productos
                    </h2>
                    <div class="w-24 h-1.5 bg-gradient-to-r from-green-400 to-blue-500 mx-auto rounded-full mb-8"></div>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                        Soluciones diseñadas específicamente para optimizar operaciones y maximizar resultados en el mercado mexicano.
                    </p>
                </div>

                <div class="grid lg:grid-cols-2 gap-12">
                    <!-- Card TrimmOS Premium -->
                    <div class="group bg-white p-1 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 hover:border-green-300">
                        <div class="p-10 h-full bg-gradient-to-br from-white to-green-50/30 rounded-3xl">
                            <div class="flex justify-between items-start mb-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-green-600 rounded-2xl flex items-center justify-center text-3xl shadow-lg">
                                        💈
                                    </div>
                                    <div>
                                        <h3 class="text-3xl font-bold text-gray-900 mb-1">TrimmOS</h3>
                                        <p class="text-green-600 font-semibold text-sm uppercase tracking-wide">Sistema de Gestión</p>
                                    </div>
                                </div>
                                <span class="bg-green-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-md">
                                    Activo
                                </span>
                            </div>
                            
                            <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                                Gestión inteligente para barberías y salones de belleza. Controla citas, inventario y finanzas con una interfaz ultrarrápida diseñada para la eficiencia operativa.
                            </p>
                            
                            <div class="grid grid-cols-2 gap-4 mb-10">
                                <div class="bg-white/70 p-4 rounded-xl border border-green-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Agenda 24/7</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Automatizada y sincronizada</p>
                                </div>
                                <div class="bg-white/70 p-4 rounded-xl border border-green-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Reportes IA</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Análisis predictivo de ventas</p>
                                </div>
                            </div>
                            
                            <a href="#" class="block text-center bg-gradient-to-r from-green-500 to-green-600 text-white py-4 rounded-2xl font-bold hover:from-green-600 hover:to-green-700 transition-all duration-300 shadow-lg hover:shadow-green-500/25">
                                Ver Demo Interactiva →
                            </a>
                        </div>
                    </div>

                    <!-- Card FactuCore Premium -->
                    <div class="group bg-white p-1 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 hover:border-blue-300">
                        <div class="p-10 h-full bg-gradient-to-br from-white to-blue-50/30 rounded-3xl">
                            <div class="flex justify-between items-start mb-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 bg-gradient-to-br from-blue-400 to-blue-600 rounded-2xl flex items-center justify-center text-3xl shadow-lg">
                                        🧾
                                    </div>
                                    <div>
                                        <h3 class="text-3xl font-bold text-gray-900 mb-1">FactuCore</h3>
                                        <p class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Automatización Fiscal</p>
                                    </div>
                                </div>
                                <span class="bg-gradient-to-r from-orange-400 to-orange-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-md">
                                    Próximamente
                                </span>
                            </div>
                            
                            <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                                Automatización fiscal inteligente que conecta directamente con el SAT. Olvídate de la complejidad administrativa y enfócate en hacer crecer tu negocio.
                            </p>
                            
                            <div class="grid grid-cols-2 gap-4 mb-10">
                                <div class="bg-white/70 p-4 rounded-xl border border-blue-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">CFDI 4.0</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Nativa y automática</p>
                                </div>
                                <div class="bg-white/70 p-4 rounded-xl border border-blue-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">IA Conciliación</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Bancaria inteligente</p>
                                </div>
                            </div>
                            
                            <div class="text-center py-4 bg-gradient-to-r from-gray-100 to-gray-200 rounded-2xl border border-gray-300">
                                <span class="text-gray-600 font-bold">Lanzamiento Q2 2026</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Call to Action -->
                <div class="text-center mt-20">
                    <div class="bg-gradient-to-r from-green-500 to-blue-600 p-1 rounded-3xl shadow-2xl">
                        <div class="bg-white rounded-3xl p-8">
                            <h3 class="text-3xl font-bold text-gray-900 mb-4">¿Listo para transformar tu operación?</h3>
                            <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
                                Únete a más de 500 empresas que ya confían en nuestras soluciones para optimizar sus procesos.
                            </p>
                            <a href="#contacto" class="inline-block bg-gradient-to-r from-green-500 to-blue-600 text-white px-10 py-4 rounded-2xl font-bold hover:from-green-600 hover:to-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105">
                                Comenzar Ahora
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN EQUIPO MODERNA -->
        <section id="equipo" class="py-32 px-6 bg-gradient-to-br from-gray-50 to-white border-y border-gray-100">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-20">
                    <div class="inline-flex items-center gap-2 bg-green-100 border border-green-200 px-4 py-2 rounded-full mb-6">
                        <span class="text-green-600">👥</span>
                        <span class="text-sm font-semibold text-green-700 uppercase tracking-wider">Nuestro Talento</span>
                    </div>
                    <h2 class="text-5xl md:text-6xl font-black tracking-tight mb-6 gradient-text">
                        Nuestro Equipo
                    </h2>
                    <div class="w-24 h-1.5 bg-gradient-to-r from-green-400 to-blue-500 mx-auto rounded-full mb-8"></div>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                        Profesionales apasionados por la tecnología y el emprendimiento, comprometidos con la excelencia 
                        y la transformación digital de empresas mexicanas.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    <!-- Miembro 1 -->
                    <div class="group bg-white p-8 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 text-center hover:border-green-300">
                        <div class="relative mb-8">
                            <div class="w-28 h-28 bg-gradient-to-br from-green-400 to-green-600 rounded-3xl mx-auto flex items-center justify-center text-4xl text-white font-black shadow-2xl transform group-hover:scale-110 transition-transform duration-300">
                                LT
                            </div>
                            <div class="absolute -top-2 -right-2 w-8 h-8 bg-orange-500 rounded-full flex items-center justify-center text-white text-sm font-bold shadow-lg">
                                ⭐
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-2">Leonardo Teófilo</h3>
                        <p class="text-green-600 font-bold mb-4 text-lg">CEO & Fundador</p>
                        <p class="text-gray-600 text-base leading-relaxed mb-6">
                            Ingeniero con más de 10 años de experiencia en desarrollo de software y transformación digital de empresas.
                        </p>
                        <div class="flex justify-center gap-3">
                            <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
                        </div>
                    </div>

                    <!-- Miembro 2 -->
                    <div class="group bg-white p-8 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 text-center hover:border-blue-300">
                        <div class="relative mb-8">
                            <div class="w-28 h-28 bg-gradient-to-br from-blue-400 to-blue-600 rounded-3xl mx-auto flex items-center justify-center text-4xl text-white font-black shadow-2xl transform group-hover:scale-110 transition-transform duration-300">
                                MR
                            </div>
                            <div class="absolute -top-2 -right-2 w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white text-sm font-bold shadow-lg">
                                🚀
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-2">María Rodríguez</h3>
                        <p class="text-blue-600 font-bold mb-4 text-lg">CTO</p>
                        <p class="text-gray-600 text-base leading-relaxed mb-6">
                            Experta en arquitectura de sistemas y liderazgo técnico, apasionada por la innovación y las nuevas tecnologías.
                        </p>
                        <div class="flex justify-center gap-3">
                            <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
                        </div>
                    </div>

                    <!-- Miembro 3 -->
                    <div class="group bg-white p-8 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 text-center hover:border-orange-300">
                        <div class="relative mb-8">
                            <div class="w-28 h-28 bg-gradient-to-br from-orange-400 to-orange-600 rounded-3xl mx-auto flex items-center justify-center text-4xl text-white font-black shadow-2xl transform group-hover:scale-110 transition-transform duration-300">
                                AG
                            </div>
                            <div class="absolute -top-2 -right-2 w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white text-sm font-bold shadow-lg">
                                🎨
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-2">Ana García</h3>
                        <p class="text-orange-600 font-bold mb-4 text-lg">Head of Product</p>
                        <p class="text-gray-600 text-base leading-relaxed mb-6">
                            Especialista en experiencia de usuario y diseño de productos digitales centrados en el cliente y la usabilidad.
                        </p>
                        <div class="flex justify-center gap-3">
                            <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                            <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                        </div>
                    </div>
                </div>

                <!-- Call to Action -->
                <div class="text-center mt-16">
                    <p class="text-gray-600 mb-6 text-lg">¿Quieres formar parte de nuestro equipo?</p>
                    <a href="#contacto" class="inline-block bg-gradient-to-r from-green-500 to-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:from-green-600 hover:to-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105">
                        Únete a Nosotros
                    </a>
                </div>
            </div>
        </section>

        <!-- SECCIÓN CONTACTO MODERNA -->
        <section id="contacto" class="py-32 px-6 bg-white">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-20">
                    <div class="inline-flex items-center gap-2 bg-orange-100 border border-orange-200 px-4 py-2 rounded-full mb-6">
                        <span class="text-orange-600">💬</span>
                        <span class="text-sm font-semibold text-orange-700 uppercase tracking-wider">Conversemos</span>
