---
import Navbar from '../components/navbar.astro';
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/Hesed-Core-logo.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Hesed Core | Innovación Tecnológica para Empresas</title>
        <!-- Tipografía moderna -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Inter', sans-serif; }
            .hero-gradient {
                background: linear-gradient(135deg, 
                    rgba(16, 185, 129, 0.05) 0%, 
                    rgba(59, 130, 246, 0.05) 50%, 
                    rgba(245, 158, 11, 0.03) 100%);
            }
            .floating-shapes {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                overflow: hidden;
                z-index: 0;
            }
            .shape {
                position: absolute;
                border-radius: 50%;
                background: linear-gradient(45deg, rgba(16, 185, 129, 0.1), rgba(59, 130, 246, 0.1));
                animation: float 6s ease-in-out infinite;
            }
            .shape:nth-child(1) {
                width: 80px;
                height: 80px;
                top: 10%;
                left: 10%;
                animation-delay: 0s;
            }
            .shape:nth-child(2) {
                width: 60px;
                height: 60px;
                top: 20%;
                right: 15%;
                animation-delay: 2s;
            }
            .shape:nth-child(3) {
                width: 100px;
                height: 100px;
                bottom: 20%;
                left: 20%;
                animation-delay: 4s;
            }
            @keyframes float {
                0%, 100% { transform: translateY(0px) rotate(0deg); }
                50% { transform: translateY(-20px) rotate(180deg); }
            }
        </style>
    </head>
    <body class="bg-white text-gray-900 hero-gradient min-h-screen">
        <Navbar />

        <!-- HERO SECTION MODERNO -->
        <section class="relative pt-24 sm:pt-28 lg:pt-32 pb-16 sm:pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
            <div class="floating-shapes">
                <div class="shape"></div>
                <div class="shape"></div>
                <div class="shape"></div>
            </div>
            
            <div class="max-w-6xl mx-auto w-full text-center relative z-10">
                
                <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl xl:text-8xl font-black tracking-tight mb-6 sm:mb-8 leading-tight">
                    Impulsamos tu <span class="gradient-text">negocio</span> con
                    <br class="hidden sm:block"><span class="text-orange-500">tecnología inteligente</span>
                </h1>
                
                <p class="text-base sm:text-lg md:text-xl text-gray-600 max-w-4xl mx-auto mb-8 sm:mb-12 leading-relaxed font-light px-0 sm:px-4">
                    Transformamos operaciones complejas en flujos automatizados. 
                    <strong class="text-gray-900 font-semibold">Hesed Core</strong> diseña ecosistemas digitales que escalan con tu crecimiento.
                </p>
                
                <!-- CTA Buttons Premium -->
                <div class="flex flex-col sm:flex-row justify-center items-stretch sm:items-center gap-4 sm:gap-6 mt-8 sm:mt-12">
                    <a href="#productos" class="group bg-gradient-to-r from-green-500 to-blue-600 text-white w-full sm:w-auto px-6 sm:px-10 lg:px-12 py-4 sm:py-5 rounded-2xl font-bold text-base sm:text-lg shadow-2xl hover:shadow-green-500/25 hover-lift transition-all duration-300">
                        <span class="flex items-center justify-center gap-3">
                            Explorar Productos
                            <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </span>
                    </a>
                    
                    <a href="#contacto" class="group bg-white border-2 border-gray-200 text-gray-700 w-full sm:w-auto px-6 sm:px-10 lg:px-12 py-4 sm:py-5 rounded-2xl font-bold text-base sm:text-lg hover:border-green-400 hover:text-green-600 transition-all duration-300 hover-lift shadow-lg">
                        <span class="flex items-center justify-center gap-3">
                            Agendar Consulta
                            <svg class="w-6 h-6 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </span>
                    </a>
                </div>

                <!-- Trust Indicators -->
                <div class="flex flex-col sm:flex-row justify-center items-center gap-6 sm:gap-8 mt-12 sm:mt-16 opacity-80 text-center">
                    <div class="max-w-xs">
                        <div class="text-lg font-semibold text-green-600 mb-1">En lanzamiento</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">TrimmOS próximamente disponible</div>
                    </div>
                    <div class="w-px h-12 bg-gray-300 hidden sm:block"></div>
                    <div class="max-w-xs">
                        <div class="text-lg font-semibold text-blue-600 mb-1">Software a medida</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">Desarrollamos ideas comerciales reales</div>
                    </div>
                    <div class="w-px h-12 bg-gray-300 hidden sm:block"></div>
                    <div class="max-w-xs">
                        <div class="text-lg font-semibold text-orange-500 mb-1">Equipo comprometido</div>
                        <div class="text-sm text-gray-500 uppercase tracking-wide">Tu proyecto recibe atención prioritaria</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN SOBRE NOSOTROS MODERNA -->
        <section id="sobre-nosotros" class="py-20 sm:py-24 lg:py-32 px-4 sm:px-6 lg:px-8 bg-white">
            <div class="max-w-7xl mx-auto">
                <div class="grid lg:grid-cols-2 gap-10 lg:gap-20 items-center min-w-0">
                    <div class="slide-up text-center lg:text-left">
                        <div class="inline-flex items-center gap-2 bg-blue-100 border border-blue-200 px-4 py-2 rounded-full mb-6">
                            <span class="text-blue-600">🎯</span>
                            <span class="text-sm font-semibold text-blue-700 uppercase tracking-wider">Nuestra Historia</span>
                        </div>
                        
                        <h2 class="text-3xl sm:text-4xl lg:text-6xl font-black tracking-tight mb-6 sm:mb-8 text-gray-900 leading-tight">
                            Innovación con <span class="gradient-text">Propósito</span>
                        </h2>
                        
                        <p class="text-lg sm:text-xl text-gray-600 mb-6 sm:mb-8 leading-relaxed">
                            Hesed Core nació en García, Nuevo León, cuando nuestro equipo reconoció que muchas barberías y salones
                            necesitaban software accesible y hecho a la medida. De esa necesidad surgió TrimmOS, nuestro primer
                            producto enfocado en agenda automática, clientes, personal y reportes inteligentes.
                        </p>
                        
                        <p class="text-lg sm:text-xl text-gray-600 mb-8 sm:mb-10 leading-relaxed">
                            Hoy conectamos esa experiencia en desarrollo con ideas comerciales reales, creando soluciones que
                            ayudan a crecer negocios locales sin complicaciones técnicas.
                        </p>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                            <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-2xl border border-green-200">
                                <div class="text-lg font-semibold text-green-600 mb-2">En crecimiento</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Proyectos reales en desarrollo</div>
                            </div>
                            <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl border border-blue-200">
                                <div class="text-lg font-semibold text-blue-600 mb-2">Compromiso real</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Clientes y negocios en proceso</div>
                            </div>
                            <div class="text-center p-4 bg-gradient-to-br from-orange-50 to-orange-100 rounded-2xl border border-orange-200">
                                <div class="text-lg font-semibold text-orange-500 mb-2">Visión clara</div>
                                <div class="text-sm text-gray-600 font-semibold uppercase tracking-wide">Equipo enfocado en escalar</div>
                            </div>
                        </div>
                        
                        <a href="#equipo" class="inline-flex items-center gap-3 bg-gradient-to-r from-green-500 to-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:from-green-600 hover:to-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl">
                            Conoce Nuestro Equipo
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                            </svg>
                        </a>
                    </div>
                    
                    <div class="relative slide-up">
                        <div class="bg-gradient-to-br from-green-400/10 to-blue-500/10 rounded-3xl p-6 sm:p-8 lg:p-12">
                            <div class="text-center">
                                <div class="w-24 h-24 bg-gradient-to-br from-green-400 to-blue-500 rounded-3xl mx-auto mb-8 flex items-center justify-center text-5xl shadow-2xl">
                                    🚀
                                </div>
                                <h3 class="text-3xl font-bold text-gray-900 mb-6">Nuestra Misión</h3>
                                <p class="text-gray-600 text-lg leading-relaxed mb-8">
                                    Democratizar el acceso a tecnología de vanguardia para empresas de todos los tamaños en México, 
                                    creando soluciones que transforman operaciones y generan crecimiento sostenible.
                                </p>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="bg-white p-4 rounded-xl border border-green-200 shadow-sm">
                                        <div class="text-2xl mb-2">⚡</div>
                                        <div class="font-semibold text-gray-800">Velocidad</div>
                                        <div class="text-sm text-gray-600">Implementación rápida</div>
                                    </div>
                                    <div class="bg-white/70 p-4 rounded-xl border border-blue-200">
                                        <div class="text-2xl mb-2">🎯</div>
                                        <div class="font-semibold text-gray-800">Precisión</div>
                                        <div class="text-sm text-gray-600">Resultados medibles</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Elementos decorativos -->
                        <div class="absolute -top-4 -right-4 w-20 h-20 bg-gradient-to-br from-orange-400 to-orange-500 rounded-2xl opacity-20 animate-pulse"></div>
                        <div class="absolute -bottom-6 -left-6 w-16 h-16 bg-gradient-to-br from-green-400 to-green-500 rounded-2xl opacity-30 animate-pulse" style="animation-delay: 1s;"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN PRODUCTOS MODERNA -->
