                <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 min-w-0">
                    <!-- Card TrimmOS Premium -->
                    <div class="group bg-white p-1 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 hover:border-green-300">
                        <div class="p-6 sm:p-8 lg:p-10 h-full bg-gradient-to-br from-white to-green-50/30 rounded-3xl">
                            <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-8">
                                <div class="flex items-center gap-4 text-left">
                                    <div class="w-16 h-16 shrink-0 bg-gradient-to-br from-green-400 to-green-600 rounded-2xl shadow-lg overflow-hidden ring-2 ring-white/80 ring-offset-2 ring-offset-green-600">
                                        <img src="/logo.png" alt="TrimmOS" class="w-full" style="height:120%; object-fit:cover; object-position:top; transform:translateY(-10%); display:block; background:#fff;" />
                                    </div>
                                    <div>
                                        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1">TrimmOS</h3>
                                        <p class="text-green-600 font-semibold text-sm uppercase tracking-wide">Sistema de Gestión</p>
                                    </div>
                                </div>
                                <span class="bg-green-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-md">
                                    Pre-lanzamiento
                                </span>
                            </div>
                            
                            <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                                TrimmOS es un SaaS para la gestión de barberías y salones. Incluye panel diario, personal, servicios, clientes y agenda automática,
                                con reportes descargables y personalización de marca para tu negocio.
                            </p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 text-left">
                                <div class="bg-white p-4 rounded-xl border border-green-100 shadow-sm">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Agenda Automática</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Automatiza reservas mediante QR.</p>
                                </div>
                                <div class="bg-white/70 p-4 rounded-xl border border-green-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Reportes PDF/Excel</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Reportes diarios, semanales y mensuales descargables en PDF y Excel.</p>
                                </div>
                            </div>
                            
                            <a href="https://youtube.com/@trimmosoficial?si=IvoS0MW5Vnrg3-yj" target="_blank" rel="noreferrer noopener" class="block text-center bg-gradient-to-r from-green-500 to-green-600 text-white py-4 rounded-2xl font-bold hover:from-green-600 hover:to-green-700 transition-all duration-300 shadow-lg hover:shadow-green-500/25">
                                Ver Demo Interactiva →
                            </a>
                        </div>
                    </div>

                    <!-- Card E-ComerCore Premium -->
                    <div class="group bg-white p-1 rounded-3xl border border-gray-200 shadow-xl hover-lift transition-all duration-500 hover:border-blue-300">
                        <div class="p-6 sm:p-8 lg:p-10 h-full bg-gradient-to-br from-white to-blue-50/30 rounded-3xl">
                            <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-8">
                                <div class="flex items-center gap-4 text-left">
                                    <div class="w-16 h-16 shrink-0 bg-gradient-to-br from-blue-400 to-blue-600 rounded-2xl flex items-center justify-center text-3xl shadow-lg">
                                        🛒
                                    </div>
                                    <div>
                                        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1">E-ComerCore</h3>
                                        <p class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Gestión para Tiendas</p>
                                    </div>
                                </div>
                                <span class="bg-gradient-to-r from-orange-400 to-orange-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-md">
                                    Próximamente
                                </span>
                            </div>
                            
                            <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                                Plataforma para tiendas con control de inventarios, proveedores, ventas y movimientos de entradas y salidas.
                                Todo el flujo administrativo listo para gestionar tu comercio con claridad.
                            </p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 text-left">
                                <div class="bg-white p-4 rounded-xl border border-blue-100 shadow-sm">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Inventarios</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Entradas y salidas en tiempo real.</p>
                                </div>
                                <div class="bg-white/70 p-4 rounded-xl border border-blue-100">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                                        <span class="font-semibold text-gray-800">Proveedores y Ventas</span>
                                    </div>
                                    <p class="text-sm text-gray-600">Gestiona compras, proveedores y facturación de ventas.</p>
                                </div>
                            </div>
                            
                            <div class="text-center py-4 bg-gradient-to-r from-gray-100 to-gray-200 rounded-2xl border border-gray-300">
                                <span class="text-gray-600 font-bold">Próximo sistema tras TrimmOS</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Call to Action -->
                <div class="text-center mt-16 lg:mt-20">
